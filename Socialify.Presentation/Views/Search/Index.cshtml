@using Socialify.Application.DTOs.Search
@model SearchDto

@{
    ViewData["Title"] = $"Search for \"{ViewBag.Query}\"";

    var pageSize = ViewBag.PageSize;
    var initialProfileCount = Model.Profiles?.TotalCount ?? 0;
    var initialPostCount = Model.Posts?.TotalCount ?? 0;
    var hasMoreProfiles = initialProfileCount > pageSize;
    var hasMorePosts = initialPostCount > pageSize;
}

<main data-query="@ViewBag.Query" data-page-size="@pageSize">
    <h2 class="mb-4 fw-light">Search results for <strong>"@ViewBag.Query"</strong></h2>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }
    else
    {
        @if (Model?.Profiles != null && Model.Profiles.Data.Any())
        {
            <h4 class="section-title">Users</h4>
            <div id="profiles-container" class="search-results-list">
                <partial name="_ProfileList" model="Model.Profiles.Data" />
            </div>
            @if (hasMoreProfiles)
            {
                <div id="load-more-profiles-container" class="text-center mt-3">
                    <button id="load-more-profiles" class="btn btn-primary">Show More</button>
                </div>
            }
        }

        @if (Model?.Posts != null && Model.Posts.Data.Any())
        {
            <h4 class="section-title mt-5">Posts</h4>
            <div id="posts-container" class="search-results-list">
                <partial name="_PostList" model="Model.Posts.Data" />
            </div>
            @if (hasMorePosts)
            {
                <div id="load-more-posts-container" class="text-center mt-3">
                    <button id="load-more-posts" class="btn btn-primary">Show More</button>
                </div>
            }
        }

        @if ((Model?.Profiles == null || !Model.Profiles.Data.Any()) && (Model?.Posts == null || !Model.Posts.Data.Any()))
        {
            <div class="text-center py-5 mt-4 no-results-container">
                <i class="fas fa-search fa-3x text-muted mb-3"></i>
                <h4>No Results Found</h4>
                <p class="text-muted">We couldn't find any users or posts matching your search.</p>
            </div>
        }
    }

</main>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            let profilePage = 2;
            let postPage = 2;

            // get main element to access data attributes
            const main = document.querySelector("main");
            const query = main.dataset.query;
            const pageSize = parseInt(main.dataset.pageSize); // ??????? ???

            // get profiles elements
            const loadMoreProfilesBtn = document.getElementById("load-more-profiles");
            const profilesContainer = document.getElementById("profiles-container");
            const loadMoreProfilesContainer = document.getElementById("load-more-profiles-container");

            // get posts elements
            const loadMorePostsBtn = document.getElementById("load-more-posts");
            const postsContainer = document.getElementById("posts-container");
            const loadMorePostsContainer = document.getElementById("load-more-posts-container");

            // load more Profiles
            loadMoreProfilesBtn?.addEventListener("click", async () => {
                const response = await fetch(`/Search/SearchMoreProfiles?query=${query}&pageNumber=${profilePage}`);
                const data = await response.text();

                if (data.trim().length > 0) {
                    profilesContainer.insertAdjacentHTML("beforeend", data);
                    profilePage++;
                    if ((new DOMParser().parseFromString(data, "text/html")).querySelectorAll(".user-card").length < pageSize) {
                        loadMoreProfilesContainer.style.display = "none";
                    }
                } else {
                    loadMoreProfilesContainer.style.display = "none";
                }
            });

            // load more posts
            loadMorePostsBtn?.addEventListener("click", async () => {
                const response = await fetch(`/Search/SearchMorePosts?query=${query}&pageNumber=${postPage}`);
                const data = await response.text();
				console.log(data);

                if (data.trim().length > 0) {
                    postsContainer.insertAdjacentHTML("beforeend", data);
                    postPage++;
                    if ((new DOMParser().parseFromString(data, "text/html")).querySelectorAll(".post-card").length < pageSize) {
                        loadMorePostsContainer.style.display = "none";
                    }
                } else {
                    loadMorePostsContainer.style.display = "none";
                }
            });
        });
    </script>
}