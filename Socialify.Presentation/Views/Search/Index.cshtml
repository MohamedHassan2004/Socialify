@using Socialify.Application.DTOs.Search
@model SearchResultDto

@{
    ViewData["Title"] = $"Search for \"{ViewBag.Query}\"";
    ViewData["CssFile"] = "Search-results.css";
}
<main>
    <h2 class="mb-4 fw-light">Search results for <strong>"@ViewBag.Query"</strong></h2>

    @* Error Handling Block *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    else
    {                
        @if (Model.Users != null && Model.Users.Any())
        {
            <h4 class="section-title">Users</h4>
            <div class="search-results-list">
                @foreach (var user in Model.Users)
                {
                    <div class="card search-result-card mb-3">
                        <div class="card-body d-flex align-items-center justify-content-between">
                            <a asp-action="Profile" asp-controller="Profile" asp-route-targetUserId="@user.Id" class="d-flex align-items-center text-decoration-none text-dark flex-grow-1">
                                <img class="result-avatar me-3" src="@user.ProfilePicUrl" alt="profile picture">
                                <div>
                                    <h5 class="mb-0 fw-bold">@user.FullName</h5>
                                </div>
                            </a>
                            <div class="ms-3">
                                @await Html.PartialAsync("_ProfileActions", user.RelationshipStatus)
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @if (Model.Posts != null && Model.Posts.Any())
        {
            <h4 class="section-title mt-5">Posts</h4>
            <div class="search-results-list">
                @foreach (var post in Model.Posts)
                {
                    <div class="card post-card mb-3">
                        <div class="card-body">
                            <div class="post-header d-flex align-items-center mb-3">
                                <img src="/@post.UserProfilePictureUrl" class="post-avatar me-3" alt="User Profile Picture">
                                <div class="post-header-info">
                                    <h6 class="mb-0 fw-bold">@post.UserName</h6>
                                    <small class="text-muted">@post.CreatedAt</small>
                                </div>
                            </div>
                            <div class="post-body">
                                <p>@post.Content</p>
                            </div>
                        </div>
                        <div class="card-footer post-footer d-flex justify-content-around">
                            <button class="post-action-btn d-flex align-items-center">
                                <i class="far fa-thumbs-up me-2"></i> <span>152 Likes</span>
                            </button>
                            <button class="post-action-btn d-flex align-items-center">
                                <i class="far fa-comment me-2"></i> <span>23 Comments</span>
                            </button>
                            <button class="post-action-btn d-flex align-items-center">
                                <i class="far fa-share-square me-2"></i> <span>Share</span>
                            </button>
                        </div>
                    </div>
                }
            </div>  
        }

        @if ((Model.Users == null || !Model.Users.Any()) && (Model.Posts == null || !Model.Posts.Any()))
        {
            <div class="text-center py-5 mt-4 no-results-container">
                <i class="fas fa-search fa-3x text-muted mb-3"></i>
                <h4>No Results Found</h4>
                <p class="text-muted">We couldn't find any users or posts matching your search.</p>
            </div>
        }
    }

</main>