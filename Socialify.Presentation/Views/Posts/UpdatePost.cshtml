    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Update Post";
}
@model Socialify.Application.DTOs.Post.UpdatePostDto

<main>
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card">
        <div class="card-body">
            <form id="postForm"
                  asp-action="UpdatePost"
                  asp-controller="Posts"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="MediaUrl" id="originalMediaUrl" />
                <input type="hidden" asp-for="MediaType" id="originalMediaType" />

                <div class="mb-3">
                    <textarea class="form-control"
                              asp-for="Content"
                              placeholder="What's on your mind?"
                              maxlength="500"></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <button type="button" id="mediaBtn" class="btn @(string.IsNullOrEmpty(Model.MediaUrl) ? "btn-outline-primary" : "btn-danger")">
                        <i class="fas @(string.IsNullOrEmpty(Model.MediaUrl) ? "fa-upload" : "fa-times")"></i>
                        @(string.IsNullOrEmpty(Model.MediaUrl) ? "Upload Media" : "Remove Media")
                    </button>
                    <input type="file"
                           class="d-none"
                           id="fileInput"
                           name="MediaFile"
                           accept="image/*,audio/*,video/*,.pdf,.doc,.docx" />
                    <input type="hidden" id="removeMedia" name="RemoveMedia" value="false" />
                    <span asp-validation-for="MediaUrl" class="text-danger"></span>
                </div>

                <div id="mediaPreview" class="mt-3">
                    @if (!string.IsNullOrEmpty(Model.MediaUrl))
                    {
                        if (Model.MediaType?.Contains("image") == true)
                        {
                            <img src="/@Model.MediaUrl" class="img-fluid rounded mb-2" style="max-height: 800px; object-fit: cover; width: 100%;" />
                        }
                        else if (Model.MediaType?.Contains("video") == true)
                        {
                            <video src="/@Model.MediaUrl" controls class="w-100 mb-2 rounded" style="max-height: 800px; object-fit: cover; width: 100%;"></video>
                        }
                        else if (Model.MediaType?.Contains("audio") == true)
                        {
                            <audio src="/@Model.MediaUrl" controls class="w-100 mb-2"></audio>
                        }
                        else
                        {
                            <div class="alert alert-info mb-2">File: @Model.MediaUrl.Split('/').Last()</div>
                        }
                    }
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-check"></i> Update
                    </button>
                    <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</main>

@section Scripts {
	<script src="~/js/media-uploader.js"></script>
    <script>
            const uploader = new MediaUploader({
            fileInputId: 'fileInput',
            previewContainerId: 'mediaPreview',
            buttonId: 'mediaBtn',
            removeMediaInputId: 'removeMedia',
            originalMediaUrl: '...',          
            originalMediaHtml: '...'          
        });
    </script>

    <partial name="_ValidationScriptsPartial" />
}