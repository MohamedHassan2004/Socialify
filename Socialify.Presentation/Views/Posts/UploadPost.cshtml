@{
    ViewData["Title"] = "Upload Post";
}

@model Socialify.Application.DTOs.Post.UploadPostDto

<main>
    <div class="card">
        <div class="card-body">
            <form id="postForm"
                  asp-action="UploadPost"
                  asp-controller="Posts"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="mb-3">
                    <textarea class="form-control"
                              asp-for="Content"
                              placeholder="What's on your mind?"
                              maxlength="500"></textarea>
                    <div class="text-muted">
                        <span id="charCount">0</span>/500 characters
                    </div>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <button type="button" id="mediaBtn" class="btn btn-outline-primary">
                        <i class="fas fa-upload"></i> Upload Media
                    </button>
                    <input type="file"
                           class="d-none"
                           id="fileInput"
                           name="MediaFile"
                           accept="image/*,audio/*,video/*,.pdf,.doc,.docx" />
                    <span asp-validation-for="MediaFile" class="text-danger"></span>
                </div>

                <div id="mediaPreview" class="mt-3 text-center"></div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane"></i> Post
                    </button>
                    <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</main>

@section Scripts {
    <script src="~/js/media-uploader.js"></script>
    <script>
        // ============================================
        // Initialize MediaUploader
        // ============================================
        const uploader = new MediaUploader({
            fileInputId: 'fileInput',
            previewContainerId: 'mediaPreview',
            buttonId: 'mediaBtn'
        });

        // يمكنك إضافة أي logic إضافي هنا لو محتاج
        // مثال: التحقق قبل الـ submit
        document.getElementById('postForm').addEventListener('submit', function(e) {
            // يمكنك استخدام uploader.hasFile() للتحقق من وجود ملف
            console.log('Has file:', uploader.hasFile());
        });
    </script>

    <script>
        // Character counter
        const textarea = document.querySelector('textarea');
        const charCount = document.getElementById('charCount');
        if (textarea && charCount) {
            textarea.addEventListener('input', function() {
                charCount.textContent = this.value.length;
            });
        }
    </script>

    <partial name="_ValidationScriptsPartial" />
}