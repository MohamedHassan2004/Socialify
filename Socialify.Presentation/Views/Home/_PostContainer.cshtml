@using System.Collections.Generic
@using Socialify.Application.DTOs.Post
@model List<PostDto>
<div class="posts-container">
	@if (Model == null || !Model.Any())
	{
		<center>
			<div class="alert alert-info mt-3">No posts available</div>
			<img src="~/images/uploads/sadVector.jpg" alt="No Posts" style="width:300px; height:auto;" />
		</center>
	}
	else
	{
		foreach (var post in Model)
		{
			@* @await Html.PartialAsync("~/Views/Shared/_Post", post) *@
		}
	}
</div>
