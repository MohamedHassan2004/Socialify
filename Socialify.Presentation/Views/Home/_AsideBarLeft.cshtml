@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    var profilePictureUrl = User.FindFirst("ProfilePic")?.Value ?? "images//profilePics//default-profile-pic.jpg";
    var fullName = User.FindFirst("FullName")?.Value ?? "Unknown User";
}

<div class="aside-bar d-none d-lg-block">
    <div class="aside-bar-container">
        <div class="card text-center user-box">
            <img src="@profilePictureUrl" class="profile-img card-img-top" alt="profile picture not found"
                 style="max-width: 100px; max-height: 100px;">
            <div class="card-body">
                <h5 class="card-title">@fullName</h5>
                <a href="" class="btn btn-primary">View Your Profile</a>
            </div>
        </div>
        <div class="card text-center mt-4">
            <ul class="list-group list-group-flush card-list">
                <li class="list-group-item">
                        <form id="logoutForm" class="" asp-controller="Account" asp-action="Logout" method="post">
                            <button id="logout" type="submit" class="border-0 d-inline bg-transparent"><i class="fas fa-sign-out-alt"></i> Logout</button>
                        </form>
                </li>
                <li class="list-group-item">
                    <a href="#"><i class="fa-solid fa-bell"></i> Notifications</a>
                </li>
                <li class="list-group-item"><a href="savedPosts.html"><i class="fas fa-bookmark"></i> Saved Posts</a></li>
                <li class="list-group-item"><a href="explore.html"><i class="far fa-compass"></i> Explore</a></li>
                <li class="list-group-item"><a href="myFriends.html"><i class="fas fa-users"></i> My Friends</a></li>
                <li class="list-group-item">
                    <a href="friendsReq.html"><i class="fas fa-user-plus"></i> Friends Requests</a>
                </li>
            </ul>
        </div>
    </div>
</div>
