@{
}

<div class="custom-alert-overlay" id="alertOverlay" onclick="closeAlert(event)">
    <div class="custom-alert" onclick="event.stopPropagation()">
        <div class="alert-icon" id="alertIcon">
            <span id="alertIconSymbol">ℹ️</span>
        </div>
        <h2 class="alert-title" id="alertTitle"></h2>
        <p class="alert-message" id="alertMessage"></p>
        <button class="alert-button" onclick="closeAlert()">Ok</button>
    </div>
</div>

<div class="custom-alert-overlay" id="confirmOverlay" onclick="closeConfirm(event)">
    <div class="custom-alert" onclick="event.stopPropagation()">
        <div class="alert-icon error">
            <span>🗑️</span>
        </div>
        <h2 class="alert-title" id="confirmTitle"></h2>
        <p class="alert-message" id="confirmMessage"></p>
        <div class="confirm-buttons">
            <button class="confirm-btn" id="confirmBtn">Confirm</button>
            <button class="cancel-btn" onclick="closeConfirm()">Cancel</button>
        </div>
    </div>
</div>