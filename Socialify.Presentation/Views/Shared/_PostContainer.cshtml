@using Socialify.Application.DTOs.Post
@model Socialify.Application.DTOs.Common.PagedResult<PostDto>

<div class="posts-container" id="posts-container">
    @if (Model == null || !Model.Data.Any())
    {
        <div class="text-center py-5 no-posts-container mt-4">
            <i class="fas fa-file-alt fa-3x text-muted mb-3"></i>
            <h4>No Posts Available</h4>
            <p class="text-muted">No posts to display at the moment.</p>
        </div>
    }
    else
    {
        @await Html.PartialAsync("_PostList", Model.Data)
    }
</div>
<div id="observer"></div>

