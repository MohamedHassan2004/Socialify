    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    var daysDiff = (DateTime.UtcNow - Model.CreatedAt).TotalDays;
}
@model Socialify.Application.DTOs.Post.PostDto

<div class="card post-card mb-4 shadow-sm border-0">
    <div class="card-body p-4">
        <!-- Post Header -->
        <div class="post-header d-flex align-items-center justify-content-between mb-3">
            <div class="d-flex align-items-center">
                <div class="position-relative">
                    <img src="/@Model.UserProfilePicUrl" class="post-avatar rounded-circle me-3" alt="User Profile Picture" style="width: 48px; height: 48px; object-fit: cover;">
                    <div class="position-absolute bottom-0 end-0 bg-success rounded-circle border border-white" style="width: 14px; height: 14px;"></div>
                </div>
                <div class="post-header-info">
                    <a asp-action="Profile" asp-controller="Profile" asp-route-targetUserId="@Model.UserId" class="d-flex align-items-center text-decoration-none text-dark flex-grow-1">
                        <h6 class="mb-0 fw-semibold">@Model.UserName</h6>
                    </a>
                    <small class="text-muted">
                        @(daysDiff > 7 ? Model.CreatedAt.ToString("dd MMM yyyy HH:mm") : Model.TimeAgo)
                    </small>
                </div>
            </div>
            
            <!-- Options Dropdown -->
            <div class="dropdown">
                <button class="btn btn-link text-muted p-1" type="button" id="postOptions-@Model.Id" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-ellipsis-h"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="postOptions-@Model.Id">
                    <li><a class="dropdown-item" href="#" onclick="editPost('@Model.Id')">
                        <i class="fas fa-edit me-2"></i>Edit Post
                    </a></li>
                    <li><a class="dropdown-item text-danger" href="#" onclick="deletePost('@Model.Id')">
                        <i class="fas fa-trash me-2"></i>Delete Post
                    </a></li>
                </ul>
            </div>
        </div>

        <!-- Post Body -->
        <div class="post-body">
            <p class="mb-3 fs-6 lh-base">@Model.Content</p>
            @if (!string.IsNullOrEmpty(Model.MediaUrl))
            {
                <div class="post-media mb-3">
                    @switch (Model.MediaType)
                    {
                        case "image":
                            <img src="/@Model.MediaUrl" alt="post image" class="img-fluid rounded-3 shadow-sm" style="max-height: 500px; object-fit: cover;" />
                            break;

                        case "video":
                            <video controls class="w-100 rounded-3 shadow-sm" style="max-height: 500px;">
                                <source src="/@Model.MediaUrl" type="video/mp4">
                                Your browser does not support the video tag.
                            </video>
                            break;

                        case "audio":
                            <div class="bg-light rounded-3 p-3 shadow-sm">
                                <audio controls class="w-100">
                                    <source src="/@Model.MediaUrl" type="audio/mpeg">
                                    Your browser does not support the audio element.
                                </audio>
                            </div>
                            break;
                    }
                </div>
            }
        </div>
    </div>

    <!-- Post Footer -->
    <div class="card-footer bg-transparent border-0 px-4 pb-4">
        <div class="d-flex justify-content-between align-items-center">
            <!-- Left side actions -->
            <div class="d-flex align-items-center gap-3">
                <button class="post-action-btn btn btn-link text-muted p-2 rounded-pill" onclick="toggleLike('@Model.Id')">
                    <i class="far fa-thumbs-up me-1"></i>
                    <span class="like-count" data-post-id="@Model.Id">@Model.LikesCount</span>
                </button>
                <button class="post-action-btn btn btn-link text-muted p-2 rounded-pill" onclick="toggleComments('@Model.Id')">
                    <i class="far fa-comment me-1"></i>
                    <span>@Model.CommentsCount</span>
                </button>
                <button class="post-action-btn btn btn-link text-muted p-2 rounded-pill" onclick="sharePost('@Model.Id')">
                    <i class="far fa-share me-1"></i>
                    <span>Share</span>
                </button>
            </div>
            
            <!-- Right side save button -->
            <button class="post-action-btn btn btn-link text-muted p-2 rounded-pill" onclick="toggleSave('@Model.Id')">
                <i class="far fa-bookmark me-1"></i>
                <span>Save</span>
            </button>
        </div>
    </div>
</div>

<!-- Likes Modal -->
<div class="modal fade" id="likesModal-@Model.Id" tabindex="-1" aria-labelledby="likesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-semibold" id="likesModalLabel">People who liked this post</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="likes-list" id="likesList-@Model.Id">
                    <!-- Likes will be loaded here via AJAX -->
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.post-card {
    background: #ffffff;
    border-radius: 12px;
    transition: all 0.3s ease;
}

.post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important;
}

.post-avatar {
    border: 2px solid #e9ecef;
    transition: border-color 0.3s ease;
}

.post-avatar:hover {
    border-color: #007bff;
}

.post-action-btn {
    transition: all 0.2s ease;
    text-decoration: none !important;
    border: none !important;
    background: none !important;
}

.post-action-btn:hover {
    background-color: #f8f9fa !important;
    color: #007bff !important;
    transform: scale(1.05);
}

.post-action-btn:focus {
    box-shadow: none !important;
}

.dropdown-menu {
    border: none;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
    border-radius: 8px;
}

.dropdown-item {
    transition: all 0.2s ease;
    border-radius: 6px;
    margin: 2px 4px;
}

.dropdown-item:hover {
    background-color: #f8f9fa;
    transform: translateX(4px);
}

.post-media img,
.post-media video {
    transition: transform 0.3s ease;
}

.post-media img:hover,
.post-media video:hover {
    transform: scale(1.02);
}

.likes-list {
    max-height: 400px;
    overflow-y: auto;
}

.like-item {
    padding: 12px 20px;
    border-bottom: 1px solid #f1f3f4;
    transition: background-color 0.2s ease;
}

.like-item:hover {
    background-color: #f8f9fa;
}

.like-item:last-child {
    border-bottom: none;
}

@media (max-width: 768px) {
    .post-card {
        margin: 0 -15px 1rem -15px;
        border-radius: 0;
    }
    
    .card-body {
        padding: 1rem !important;
    }
    
    .post-action-btn {
        padding: 0.5rem !important;
        font-size: 0.9rem;
    }
}
</style>

<script>
function toggleLike(postId) {
    // Toggle like functionality
    const likeBtn = document.querySelector(`[data-post-id="${postId}"]`).closest('.post-action-btn');
    const likeCount = document.querySelector(`[data-post-id="${postId}"]`);
    const icon = likeBtn.querySelector('i');
    
    // Toggle visual state
    if (icon.classList.contains('far')) {
        icon.classList.remove('far');
        icon.classList.add('fas');
        likeBtn.classList.add('text-primary');
    } else {
        icon.classList.remove('fas');
        icon.classList.add('far');
        likeBtn.classList.remove('text-primary');
    }
    
    // Show likes modal when clicking on count
    showLikesModal(postId);
}

function showLikesModal(postId) {
    const modal = new bootstrap.Modal(document.getElementById(`likesModal-${postId}`));
    modal.show();
    
    // Load likes via AJAX
    loadLikes(postId);
}

function loadLikes(postId) {
    // Simulate AJAX call to load likes
    const likesList = document.getElementById(`likesList-${postId}`);
    likesList.innerHTML = `
        <div class="like-item d-flex align-items-center">
            <img src="/default-avatar.jpg" class="rounded-circle me-3" style="width: 40px; height: 40px;" alt="User">
            <div>
                <h6 class="mb-0">John Doe</h6>
                <small class="text-muted">Software Engineer</small>
            </div>
        </div>
        <div class="like-item d-flex align-items-center">
            <img src="/default-avatar.jpg" class="rounded-circle me-3" style="width: 40px; height: 40px;" alt="User">
            <div>
                <h6 class="mb-0">Jane Smith</h6>
                <small class="text-muted">Product Manager</small>
            </div>
        </div>
    `;
}

function toggleComments(postId) {
    // Toggle comments functionality
    console.log('Toggle comments for post:', postId);
}

function sharePost(postId) {
    // Share post functionality
    if (navigator.share) {
        navigator.share({
            title: 'Check out this post',
            url: window.location.href
        });
    } else {
        // Fallback to copy link
        navigator.clipboard.writeText(window.location.href);
        alert('Link copied to clipboard!');
    }
}

function toggleSave(postId) {
    // Toggle save functionality
    const saveBtn = document.querySelector(`[onclick="toggleSave('${postId}')"]`);
    const icon = saveBtn.querySelector('i');
    
    if (icon.classList.contains('far')) {
        icon.classList.remove('far');
        icon.classList.add('fas');
        saveBtn.classList.add('text-warning');
    } else {
        icon.classList.remove('fas');
        icon.classList.add('far');
        saveBtn.classList.remove('text-warning');
    }
}

function editPost(postId) {
    // Edit post functionality
    console.log('Edit post:', postId);
}

function deletePost(postId) {
    // Delete post functionality
    if (confirm('Are you sure you want to delete this post?')) {
        console.log('Delete post:', postId);
    }
}
</script>