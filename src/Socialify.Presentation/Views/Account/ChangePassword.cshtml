@{
}

@using Socialify.Application.DTOs.Account
@model ChangePasswordDto

@{
    ViewData["Title"] = "Change Password";
    ViewData["CssFile"] = "Forms.css";
}


<div class="form-card">
    <div class="brand-header">
        <h1>Socialify</h1>
    </div>

    <form asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()

        <div class="title"><h2>Change Password</h2></div>
        
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="mb-2">
            <label asp-for="CurrentPassword" class="form-label"></label>
            <div class="input-group">
                <input asp-for="CurrentPassword" class="form-control" id="inputPassword" required type="password" />
                <span class="input-group-text" id="togglePassword" style="cursor:pointer">
                    <i class="fa-solid fa-eye" id="eyeIcon"></i>
                </span>
            </div>
            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
        </div>

        <div class="mb-2">
            <label asp-for="NewPassword" class="form-label"></label>
            <div class="input-group">
                <input asp-for="NewPassword" class="form-control" required type="password" />
            </div>
            <span asp-validation-for="NewPassword" class="text-danger"></span>
        </div>

        <div class="mb-2">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <div class="input-group">
                <input asp-for="ConfirmPassword" class="form-control" required type="password" />
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Save</button>

        <div class="link">
            <a asp-controller="Home" asp-action="Index">Back Home</a>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/togglePassword.js"></script>
}