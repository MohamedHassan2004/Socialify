@model ErrorViewModel
@{
    ViewData["Title"] = "An Error Occurred";
}

<main>
    <h1 class="text-danger">Oops! Something went wrong.</h1>
    <p class="lead text-muted">
        We're sorry, but an unexpected error occurred while processing your request.
    </p>

    <hr class="my-4">

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>Details:</strong> @TempData["ErrorMessage"]
        </div>
    }
    else
    {
        <p>Please try again later, or contact support if the problem persists.</p>
    }

    <div class="mt-4">
        <a asp-action="Index" asp-controller="Home" class="btn btn-primary btn-lg" role="button">
            Go to Homepage
        </a>
        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg ms-2" role="button">
            Go Back
        </a>
    </div>

</main>