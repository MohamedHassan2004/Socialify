@{
}
@model ProfileBasicInfoDto

<div class="card user-card mb-3">
    <div class="card-body d-flex align-items-center justify-content-between">
        <a asp-action="Profile" asp-controller="Profile" asp-route-targetUserId="@Model.Id" class="d-flex align-items-center text-decoration-none text-dark flex-grow-1">
            <img class="user-avatar me-3" src="/@Model.ProfilePicUrl" alt="profile picture">
            <div>
                <h5 class="mb-0 fw-bold">@Model.FullName</h5>
                @if (!string.IsNullOrEmpty(Model.Bio))
                {
                    <p class="text-muted">@Model.Bio</p>
                }
            </div>
        </a>
        <div class="ms-3">
            @await Html.PartialAsync("_ProfileActions", Model)
        </div>
    </div>
</div>