@model Socialify.Application.DTOs.Common.PagedResult<Socialify.Application.DTOs.Post.PostDto>

@{
    ViewData["CssFile"] = "HomePage.css";
}

<main>
    <h2>Explore</h2>
    <p>Discover new content and connect with others!</p>
    <hr />

    @if (Model != null && Model.Data != null && Model.Data.Any())
    {
        <div id="posts-section" data-page-size="@Model.PageSize" data-total-pages="@Model.TotalPages">
            @await Html.PartialAsync("_PostContainer", Model)
        </div>
    }
    else
    {
        <div class="card post-card p-4">
            <h5>No posts available</h5>
            <p>Check back later for new posts!</p>
        </div>
    }
</main>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            initInfiniteScroll({
                sectionId: "posts-section",
                containerId: "posts-container",
                observerId: "observer",
                apiUrl: "/Posts/LoadExplorePosts"
            });
        });
    </script>
}