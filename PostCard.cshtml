@model Socialify.Application.DTOs.Post.PostDto
@{
    var daysDiff = (DateTime.UtcNow - Model.CreatedAt).TotalDays;
}

<div class="card post-card shadow-sm mb-4">
    <div class="card-body p-4">
        <!-- Post Header -->
        <div class="post-header d-flex align-items-start mb-3">
            <img src="/@Model.UserProfilePicUrl" class="post-avatar rounded-circle me-3" alt="@Model.UserName Profile Picture">
            <div class="post-header-info flex-grow-1">
                <a asp-action="Profile" asp-controller="Profile" asp-route-targetUserId="@Model.UserId" class="text-decoration-none">
                    <h6 class="mb-0 fw-semibold text-dark post-username">@Model.UserName</h6>
                </a>
                <small class="text-muted d-block">
                    <i class="far fa-clock me-1"></i>
                    @(daysDiff > 7 ? Model.CreatedAt.ToString("dd MMM yyyy HH:mm") : Model.TimeAgo)
                </small>
            </div>
            <!-- Options Menu -->
            <div class="dropdown">
                <button class="btn btn-link text-muted post-options-btn p-1" type="button" id="postOptions@(Model.Id)" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="fas fa-ellipsis-h"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="postOptions@(Model.Id)">
                    <li>
                        <a class="dropdown-item" href="#" onclick="editPost('@Model.Id'); return false;">
                            <i class="fas fa-edit me-2 text-primary"></i> Edit Post
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item text-danger" href="#" onclick="deletePost('@Model.Id'); return false;">
                            <i class="fas fa-trash-alt me-2"></i> Delete Post
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Post Body -->
        <div class="post-body mb-3">
            <p class="post-content mb-3">@Model.Content</p>
            @if (!string.IsNullOrEmpty(Model.MediaUrl))
            {
                <div class="post-media rounded overflow-hidden">
                    @switch (Model.MediaType)
                    {
                        case "image":
                            <img src="/@Model.MediaUrl" alt="Post image" class="img-fluid w-100 post-image" />
                            break;

                        case "video":
                            <video controls class="w-100 post-video">
                                <source src="/@Model.MediaUrl" type="video/mp4">
                                Your browser does not support the video tag.
                            </video>
                            break;

                        case "audio":
                            <div class="p-3 bg-light rounded">
                                <audio controls class="w-100 post-audio">
                                    <source src="/@Model.MediaUrl" type="audio/mpeg">
                                    Your browser does not support the audio element.
                                </audio>
                            </div>
                            break;
                    }
                </div>
            }
        </div>
    </div>

    <!-- Post Footer -->
    <div class="card-footer bg-white border-top py-2 px-4">
        <div class="d-flex justify-content-between align-items-center">
            <!-- Left Side Actions -->
            <div class="post-actions d-flex gap-2">
                <!-- Like Button with Count -->
                <button class="post-action-btn btn btn-sm d-flex align-items-center px-3 py-2" onclick="toggleLike('@Model.Id')">
                    <i class="far fa-thumbs-up me-2"></i>
                    <span class="post-action-text">Like</span>
                </button>
                <button class="post-likes-count btn btn-sm text-muted px-2 py-2" data-bs-toggle="modal" data-bs-target="#likesModal@(Model.Id)" title="View who liked this post">
                    <span class="fw-semibold">@Model.LikesCount</span>
                </button>
                
                <!-- Comment Button -->
                <button class="post-action-btn btn btn-sm d-flex align-items-center px-3 py-2" onclick="showComments('@Model.Id')">
                    <i class="far fa-comment me-2"></i>
                    <span class="post-action-text">Comment</span>
                    <span class="badge bg-secondary ms-2">@Model.CommentsCount</span>
                </button>
                
                <!-- Share Button -->
                <button class="post-action-btn btn btn-sm d-flex align-items-center px-3 py-2" onclick="sharePost('@Model.Id')">
                    <i class="fas fa-share me-2"></i>
                    <span class="post-action-text">Share</span>
                </button>
            </div>

            <!-- Right Side Save Button -->
            <div class="post-save-action">
                <button class="post-action-btn btn btn-sm d-flex align-items-center px-3 py-2" onclick="toggleSave('@Model.Id')">
                    <i class="far fa-bookmark me-2"></i>
                    <span class="post-action-text">Save</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Likes Modal -->
<div class="modal fade" id="likesModal@(Model.Id)" tabindex="-1" aria-labelledby="likesModalLabel@(Model.Id)" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-semibold" id="likesModalLabel@(Model.Id)">
                    <i class="fas fa-thumbs-up text-primary me-2"></i>Liked by
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-2" id="likesModalBody@(Model.Id)">
                <!-- Likes list will be loaded here via AJAX -->
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Post Card Styling */
    .post-card {
        border: 1px solid #e4e6eb;
