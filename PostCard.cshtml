    }

    /* Post Header */
    .post-avatar {
        width: 48px;
        height: 48px;
        object-fit: cover;
        border: 2px solid #f0f2f5;
    }

    .post-username {
        font-size: 15px;
        transition: color 0.2s ease;
    }

    .post-username:hover {
        color: #1877f2 !important;
    }

    .post-header-info small {
        font-size: 13px;
    }

    .post-options-btn {
        border-radius: 50%;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background-color 0.2s ease;
    }

    .post-options-btn:hover {
        background-color: #f0f2f5;
    }

    .post-options-btn i {
        font-size: 18px;
    }

    /* Dropdown Menu */
    .dropdown-menu {
        border: 1px solid #e4e6eb;
        border-radius: 8px;
        min-width: 200px;
    }

    .dropdown-item {
        padding: 10px 16px;
        font-size: 14px;
        transition: background-color 0.2s ease;
    }

    .dropdown-item:hover {
        background-color: #f0f2f5;
    }

    .dropdown-item i {
        font-size: 14px;
    }

    /* Post Body */
    .post-content {
        font-size: 15px;
        line-height: 1.6;
        color: #050505;
        white-space: pre-wrap;
        word-wrap: break-word;
    }

    .post-media {
        background-color: #f0f2f5;
        max-height: 600px;
        overflow: hidden;
    }

    .post-image {
        object-fit: contain;
        max-height: 600px;
        cursor: pointer;
        transition: transform 0.2s ease;
    }

    .post-image:hover {
        transform: scale(1.01);
    }

    .post-video,
    .post-audio {
        outline: none;
    }

    /* Post Footer */
    .card-footer {
        border-top: 1px solid #e4e6eb !important;
    }

    .post-action-btn {
        border: none;
        background: transparent;
        color: #65676b;
        font-size: 14px;
        font-weight: 500;
        border-radius: 6px;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .post-action-btn:hover {
        background-color: #f0f2f5;
        color: #050505;
    }

    .post-action-btn i {
        font-size: 16px;
    }

    .post-likes-count {
        border: none;
        background: transparent;
        color: #65676b;
        font-size: 14px;
        border-radius: 6px;
        transition: all 0.2s ease;
        cursor: pointer;
        padding: 0.375rem 0.5rem;
    }

    .post-likes-count:hover {
        background-color: #f0f2f5;
        color: #1877f2;
        text-decoration: underline;
    }

    .post-action-text {
        white-space: nowrap;
    }

    /* Badge */
    .badge {
        font-size: 11px;
        font-weight: 600;
        padding: 3px 7px;
        border-radius: 10px;
    }

    /* Modal Styling */
    .modal-content {
        border-radius: 12px;
        border: none;
    }

    .modal-header {
        padding: 1.25rem 1.5rem;
    }

    .modal-body {
        padding: 1rem 1.5rem;
        max-height: 400px;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
        .post-card {
            border-radius: 0;
            border-left: none;
            border-right: none;
        }

        .post-action-text {
            display: none;
        }

        .post-action-btn {
            padding: 0.5rem !important;
        }

        .post-actions {
            gap: 0.25rem !important;
        }

        .card-body {
            padding: 1rem !important;
        }

        .card-footer {
            padding-left: 0.75rem !important;
            padding-right: 0.75rem !important;
        }
    }

    @media (max-width: 576px) {
        .post-avatar {
            width: 40px;
            height: 40px;
        }

        .post-username {
            font-size: 14px;
        }

        .post-content {
            font-size: 14px;
        }
    }
</style>

